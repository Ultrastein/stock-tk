# ===========================================
# BASE DE DATOS — PostgreSQL LOCAL (On-Premise)
# Ajustar según la IP de la máquina física
# que aloja la DB en la red local.
# ===========================================
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=control_stock
DB_USER=postgres
DB_PASSWORD=cambia_esta_clave_segura
DB_POOL_MAX=10
DB_POOL_MIN=0

# ===========================================
# AUTENTICACIÓN JWT
# ===========================================
JWT_SECRET=genera-un-secreto-largo-y-aleatorio-aqui
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# SERVIDOR
# ===========================================
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ===========================================
# COLD STORAGE — Archivado local / NAS
# Puede ser un path local o un mount de NAS:
#   Local:   /srv/control-stock/cold-storage
#   NAS:     /mnt/nas/control-stock/cold-storage
#   Windows: C:/backups/control-stock/cold-storage
# ===========================================
COLD_STORAGE_PATH=./cold-storage
COLD_STORAGE_RETENTION_YEARS=3

# ===========================================
# IMPORTACIÓN MASIVA (Excel/CSV)
# ===========================================
UPLOAD_MAX_SIZE_MB=20
UPLOAD_TEMP_DIR=./uploads/temp

# ===========================================
# FIREBASE AUTHENTICATION (Google / Apple)
# Cómo obtener estas credenciales:
#   1. Ir a https://console.firebase.google.com
#   2. Seleccionar tu proyecto → Project Settings → Service Accounts
#   3. Click "Generate new private key" → descargar el JSON
#   4. Copiar los valores del JSON a estas variables:
#      JSON "project_id"    → FIREBASE_PROJECT_ID
#      JSON "client_email"  → FIREBASE_CLIENT_EMAIL
#      JSON "private_key"   → FIREBASE_PRIVATE_KEY  (entre comillas dobles)
# ===========================================
FIREBASE_PROJECT_ID=tu-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvAIBAD...\n-----END PRIVATE KEY-----\n"
